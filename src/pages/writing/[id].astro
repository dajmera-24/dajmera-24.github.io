---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Tag from '../../components/Tag.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={d.title} description={d.description}>
  <article class="section-tight container post">
    <a href="/writing/" class="link-arrow post__back">
      <Icon name="arrow-right" size={15} class="post__back-icon" /> All writing
    </a>

    <header class="post__header prose-width" data-reveal>
      <p class="eyebrow">
        <time datetime={d.date.toISOString()}>{fmt(d.date)}</time>
      </p>
      <h1 class="post__title text-balance">{d.title}</h1>
      <p class="post__lead muted text-pretty">{d.description}</p>
      <div class="post__tags">
        {d.tags.map((t) => <Tag label={t} />)}
      </div>
    </header>

    <hr class="divider post__rule" />

    <div class="prose prose-width" data-reveal style="--index: 1">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 52rem;
  }
  .post__back {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  .post__back :global(.post__back-icon) {
    transform: rotate(180deg);
  }
  .post__title {
    font-size: clamp(2.2rem, 5.2vw, 3.4rem);
    margin-top: 0.7rem;
  }
  .post__lead {
    font-size: 1.2rem;
    line-height: 1.5;
    margin-top: 1.1rem;
  }
  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.4rem;
  }
  .post__rule {
    margin-block: clamp(2rem, 4vw, 3rem);
  }
</style>
