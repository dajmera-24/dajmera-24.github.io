---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import Icon from '../components/Icon.astro';
import Tag from '../components/Tag.astro';
import { site, socials } from '../site';

const pubs = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year)
  .filter((p) => p.data.featured)
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('writing'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const areas = [
  {
    icon: 'atom',
    title: 'Spectral & dynamic graph algorithms',
    body: 'Maintaining structure — sparsifiers, cuts, clusterings — efficiently as graphs change over time, even adversarially.',
    span: true,
  },
  {
    icon: 'sigma',
    title: 'Convex optimization',
    body: 'First-order methods where the analysis and the implementation stay close together.',
  },
  {
    icon: 'book',
    title: 'Learning theory & robust statistics',
    body: 'Provable guarantees for estimation when a fraction of the data is corrupted.',
  },
  {
    icon: 'code',
    title: 'Formal mathematics',
    body: 'Machine-checked proofs in Lean, with a focus on the probabilistic method.',
    span: true,
  },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero__name eyebrow" data-reveal>
        <span class="hero__dot" aria-hidden="true"></span>
        {site.name}: {site.role}
      </p>
      <h1 class="hero__title serif text-balance" data-reveal style="--index: 1">
        I study the mathematics behind algorithms that stay fast when the data keeps
        changing.
      </h1>
      <p class="hero__lead muted text-pretty" data-reveal style="--index: 2">
        {site.tagline}
      </p>
      <div class="hero__actions" data-reveal style="--index: 3">
        <a class="btn btn--primary" href="/research/">
          Read the research <Icon name="arrow-right" size={17} />
        </a>
        <a class="btn btn--ghost" href="/cv/">
          <Icon name="file" size={17} /> View CV
        </a>
      </div>

      <dl class="hero__facts" data-reveal style="--index: 4">
        <div>
          <dt class="eyebrow">Affiliation</dt>
          <dd>{site.affiliation}</dd>
        </div>
        <div>
          <dt class="eyebrow">Based in</dt>
          <dd>{site.location}</dd>
        </div>
        <div>
          <dt class="eyebrow">Currently</dt>
          <dd>Studying Measure Theory</dd>
        </div>
      </dl>
    </div>
  </section>

  {/* Hidden for now — uncomment to restore the Research focus bento on the homepage.
  <hr class="divider" />

  <!-- Research focus -->
  <section class="section container">
    <SectionHead
      eyebrow="What I think about"
      title="Research focus"
      href="/research/"
      linkLabel="Full research statement"
    />
    <div class="bento">
      {
        areas.map((a, i) => (
          <article
            class:list={['card', 'card-hover', 'area', { 'area--wide': a.span }]}
            data-reveal
            style={`--index: ${i}`}
          >
            <span class="area__icon">
              <Icon name={a.icon} size={22} />
            </span>
            <h3 class="area__title">{a.title}</h3>
            <p class="muted area__body">{a.body}</p>
          </article>
        ))
      }
    </div>
  </section>
  */}

  <hr class="divider" />

  <!-- Selected publications -->
  <section class="section container">
    <SectionHead
      eyebrow="Selected work"
      title="Research"
      href="/publications/"
      linkLabel="All research"
    />
    <ul class="pub-list">
      {
        pubs.map((p, i) => (
          <li class="pub" data-reveal style={`--index: ${i}`}>
            <span class="pub__year mono">{p.data.year}</span>
            <div class="pub__body">
              <h3 class="pub__title">{p.data.title}</h3>
              <p class="pub__authors muted">{p.data.authors.join(', ')}</p>
              <p class="pub__venue">
                <em class="serif">{p.data.venue}</em>
                <Tag label={p.data.type} variant="neutral" />
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  {/* Hidden for now — uncomment to restore Projects and Writing sections on the homepage.
  <hr class="divider" />

  <!-- Featured projects -->
  <section class="section container">
    <SectionHead
      eyebrow="Things I have built"
      title="Projects"
      href="/projects/"
      linkLabel="All projects"
    />
    <div class="proj-grid">
      {
        projects.map((p, i) => (
          <a href={`/projects/${p.id}/`} class="card card-hover proj" data-reveal style={`--index: ${i}`}>
            <div class="proj__top">
              <Icon name="code" size={20} />
              <span class="mono proj__year">{p.data.year}</span>
            </div>
            <h3 class="proj__title">{p.data.title}</h3>
            <p class="muted proj__summary">{p.data.summary}</p>
            <div class="proj__tags">
              {p.data.tags.map((t) => <Tag label={t} />)}
            </div>
            <span class="link-arrow proj__more">
              View project <Icon name="arrow-up-right" size={15} />
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <hr class="divider" />

  <!-- Recent writing -->
  <section class="section container">
    <SectionHead
      eyebrow="Notes & essays"
      title="Writing"
      href="/writing/"
      linkLabel="All writing"
    />
    <ul class="write-list">
      {
        posts.map((p, i) => (
          <li data-reveal style={`--index: ${i}`}>
            <a href={`/writing/${p.id}/`} class="write">
              <time class="mono write__date" datetime={p.data.date.toISOString()}>
                {fmt(p.data.date)}
              </time>
              <div class="write__body">
                <h3 class="write__title">{p.data.title}</h3>
                <p class="muted write__desc">{p.data.description}</p>
              </div>
              <Icon name="arrow-up-right" size={16} class="write__arrow" />
            </a>
          </li>
        ))
      }
    </ul>
  </section>
  */}

  <!-- Contact -->
  <section class="section-tight">
    <div class="container">
      <div class="contact card" data-reveal>
        <div>
          <p class="eyebrow">Get in touch</p>
          <h2 class="contact__title serif">Let's talk about hard problems.</h2>
          <p class="muted contact__lead text-pretty">
            I'm always happy to discuss research, collaborations, or anything math-related.
            The fastest way to reach me is email.
          </p>
        </div>
        <div class="contact__actions">
          <a class="btn btn--primary" href={`mailto:${site.email}`}>
            <Icon name="mail" size={17} /> {site.email}
          </a>
          <div class="contact__socials">
            {
              socials
                .filter((s) => !s.href.startsWith('mailto:'))
                .map((s) => (
                  <a class="contact__social" href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
                    <Icon name={s.icon} size={18} />
                  </a>
                ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-block: clamp(4rem, 11vw, 9rem) clamp(3rem, 7vw, 6rem);
  }
  .hero__name {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.78rem;
  }
  .hero__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--pale-green-fg);
    box-shadow: 0 0 0 3px var(--pale-green-bg);
  }
  .hero__title {
    font-size: clamp(2.4rem, 6.4vw, 4.6rem);
    max-width: 18ch;
    margin-top: 1.4rem;
  }
  .hero__lead {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    max-width: 56ch;
    margin-top: 1.6rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.2rem;
  }
  .hero__facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: clamp(2.5rem, 6vw, 4rem);
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    max-width: 46rem;
  }
  .hero__facts dt {
    margin-bottom: 0.4rem;
  }
  .hero__facts dd {
    font-size: 0.95rem;
    color: var(--text);
  }

  /* Bento */
  .bento {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .area {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .area--wide {
    grid-column: span 2;
  }
  .area__icon {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: var(--radius-sm);
    background: var(--bg-bone);
    border: 1px solid var(--border-soft);
    color: var(--text-strong);
    margin-bottom: 0.25rem;
  }
  .area__title {
    font-size: 1.2rem;
    line-height: 1.25;
  }
  .area__body {
    font-size: 0.95rem;
  }

  /* Publications list */
  .pub-list {
    border-top: 1px solid var(--border);
  }
  .pub {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1.5rem;
    padding-block: 1.6rem;
    border-bottom: 1px solid var(--border);
  }
  .pub__year {
    font-size: 0.85rem;
    color: var(--text-muted);
    padding-top: 0.2rem;
  }
  .pub__title {
    font-size: 1.25rem;
    line-height: 1.3;
  }
  .pub__authors {
    font-size: 0.9rem;
    margin-top: 0.35rem;
  }
  .pub__venue {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.6rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  /* Projects */
  .proj-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .proj {
    display: flex;
    flex-direction: column;
    color: inherit;
  }
  .proj__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }
  .proj__year {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .proj__title {
    font-size: 1.4rem;
  }
  .proj__summary {
    font-size: 0.95rem;
    margin-top: 0.6rem;
  }
  .proj__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.1rem;
  }
  .proj__more {
    font-size: 0.88rem;
    margin-top: 1.4rem;
  }

  /* Writing */
  .write-list {
    border-top: 1px solid var(--border);
  }
  .write {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    align-items: baseline;
    gap: 1.5rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--border);
    transition: background-color 180ms var(--ease-out);
  }
  .write:hover {
    background: var(--surface-alt);
  }
  .write__date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .write__title {
    font-size: 1.2rem;
  }
  .write__desc {
    font-size: 0.93rem;
    margin-top: 0.3rem;
  }
  .write__arrow {
    color: var(--text-muted);
    align-self: center;
  }
  .write:hover .write__arrow {
    color: var(--text-strong);
  }

  /* Contact */
  .contact {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: var(--bg-bone);
    padding: clamp(2rem, 5vw, 3.5rem);
  }
  .contact__title {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    margin-top: 0.5rem;
  }
  .contact__lead {
    font-size: 1rem;
    margin-top: 0.8rem;
    max-width: 42ch;
  }
  .contact__actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .contact__socials {
    display: flex;
    gap: 0.4rem;
  }
  .contact__social {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--text-secondary);
    transition: color 180ms var(--ease-out), border-color 180ms var(--ease-out), transform 180ms var(--ease-out);
  }
  .contact__social:hover {
    color: var(--text-strong);
    border-color: #cfcfcf;
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 860px) {
    .bento,
    .proj-grid {
      grid-template-columns: 1fr;
    }
    .area--wide {
      grid-column: auto;
    }
  }
  @media (max-width: 620px) {
    .hero__facts {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .pub {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .write {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .write__arrow {
      display: none;
    }
  }
</style>
