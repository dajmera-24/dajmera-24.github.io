---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Icon from '../../components/Icon.astro';
import Tag from '../../components/Tag.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Projects"
  description="Open-source software and research tools by Dhruv Ajmera."
>
  <PageHeader
    eyebrow="Projects"
    title="Software & research tools"
    lead="Most of these started as the implementation behind a paper or a course and grew into something I keep maintaining. Nearly all are open source."
  />

  <section class="section-tight container">
    <div class="grid">
      {
        projects.map((p, i) => (
          <article class="card card-hover proj" data-reveal style={`--index: ${i % 3}`}>
            <div class="proj__top">
              <span class="proj__icon">
                <Icon name="code" size={20} />
              </span>
              <span class="mono proj__year">{p.data.year}</span>
            </div>
            <a href={`/projects/${p.id}/`} class="proj__title-link">
              <h2 class="proj__title">{p.data.title}</h2>
            </a>
            <p class="muted proj__summary text-pretty">{p.data.summary}</p>

            {p.data.stack.length > 0 && (
              <p class="proj__stack mono">{p.data.stack.join(' · ')}</p>
            )}

            <div class="proj__tags">
              {p.data.tags.map((t) => (
                <Tag label={t} />
              ))}
            </div>

            <div class="proj__links">
              <a href={`/projects/${p.id}/`} class="link-arrow proj__detail">
                Details <Icon name="arrow-right" size={15} />
              </a>
              <div class="proj__ext">
                {p.data.repo && (
                  <a href={p.data.repo} target="_blank" rel="noopener" aria-label="Source code">
                    <Icon name="github" size={18} />
                  </a>
                )}
                {p.data.demo && (
                  <a href={p.data.demo} target="_blank" rel="noopener" aria-label="Live demo">
                    <Icon name="arrow-up-right" size={18} />
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .proj {
    display: flex;
    flex-direction: column;
  }
  .proj__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.1rem;
  }
  .proj__icon {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: var(--radius-sm);
    background: var(--bg-bone);
    border: 1px solid var(--border-soft);
    color: var(--text-strong);
  }
  .proj__year {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .proj__title-link {
    color: inherit;
  }
  .proj__title {
    font-size: 1.4rem;
  }
  .proj__title-link:hover .proj__title {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
  }
  .proj__summary {
    font-size: 0.95rem;
    margin-top: 0.6rem;
    flex-grow: 1;
  }
  .proj__stack {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 1rem;
    letter-spacing: 0.01em;
  }
  .proj__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.9rem;
  }
  .proj__links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.4rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--border-soft);
  }
  .proj__detail {
    font-size: 0.88rem;
  }
  .proj__ext {
    display: flex;
    gap: 0.6rem;
    color: var(--text-secondary);
  }
  .proj__ext a {
    transition: color 160ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .proj__ext a:hover {
    color: var(--text-strong);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
