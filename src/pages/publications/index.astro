---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Icon from '../../components/Icon.astro';
import Tag from '../../components/Tag.astro';
import { site } from '../../site';

const all = (await getCollection('publications')).sort((a, b) => {
  if (b.data.year !== a.data.year) return b.data.year - a.data.year;
  return a.data.title.localeCompare(b.data.title);
});

const years = [...new Set(all.map((p) => p.data.year))].sort((a, b) => b - a);

// Bold the author's own name within the author list.
const isMe = (name: string) => name === site.name;

const typeVariant: Record<string, 'red' | 'blue' | 'green' | 'yellow' | 'violet'> = {
  preprint: 'yellow',
  conference: 'blue',
  journal: 'green',
  workshop: 'violet',
  thesis: 'red',
};
---

<BaseLayout
  title="Research"
  description="Research papers and preprints by Dhruv Ajmera in algorithms and combinatorics."
>
  <PageHeader
    eyebrow="Research"
    title="Fast algorithms, rigorous proofs."
    lead="My work is currently concentrated in algorithms and combinatorics. However, I am currently expanding into stochastic calculus and financial applications!"
  />

  <section class="section-tight container">
    {
      years.map((year) => (
        <div class="year-block" data-reveal>
          <div class="year-rail">
            <h2 class="year mono">{year}</h2>
          </div>
          <ul class="year-list">
            {all
              .filter((p) => p.data.year === year)
              .map((p) => (
                <li class="entry">
                  <div class="entry__head">
                    <h3 class="entry__title">{p.data.title}</h3>
                    <Tag label={p.data.type} variant={typeVariant[p.data.type]} />
                  </div>
                  <p class="entry__authors">
                    {p.data.authors.map((a, idx) => (
                      <>
                        <span class:list={[{ 'entry__me': isMe(a) }]}>{a}</span>
                        {idx < p.data.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>
                  <p class="entry__venue serif">{p.data.venue}</p>
                  {p.data.abstract && (
                    <p class="entry__abstract muted text-pretty">{p.data.abstract}</p>
                  )}
                  {p.data.award && (
                    <p class="entry__award">
                      <Icon name="star" size={15} />
                      {p.data.award}
                    </p>
                  )}
                  <div class="entry__links">
                    {p.data.pdf && (
                      <a class="reslink" href={p.data.pdf} target="_blank" rel="noopener">
                        <Icon name="file" size={15} /> PDF
                      </a>
                    )}
                    {p.data.arxiv && (
                      <a class="reslink" href={p.data.arxiv} target="_blank" rel="noopener">
                        <Icon name="link" size={15} /> arXiv
                      </a>
                    )}
                    {p.data.code && (
                      <a class="reslink" href={p.data.code} target="_blank" rel="noopener">
                        <Icon name="code" size={15} /> Code
                      </a>
                    )}
                  </div>
                </li>
              ))}
          </ul>
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .year-block {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.5rem;
    padding-block: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--border);
  }
  .year-block:last-child {
    border-bottom: 1px solid var(--border);
  }
  .year-rail {
    position: relative;
  }
  .year {
    position: sticky;
    top: 5.5rem;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  .year-list {
    display: grid;
    gap: 2.75rem;
  }
  .entry__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .entry__title {
    font-size: 1.3rem;
    line-height: 1.3;
  }
  .entry__head :global(.tag) {
    flex-shrink: 0;
    margin-top: 0.2rem;
  }
  .entry__authors {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }
  .entry__me {
    color: var(--text-strong);
    font-weight: 500;
  }
  .entry__venue {
    font-style: italic;
    font-size: 1.02rem;
    color: var(--text);
    margin-top: 0.35rem;
  }
  .entry__abstract {
    font-size: 0.95rem;
    margin-top: 0.8rem;
    max-width: 62ch;
  }
  .entry__award {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--pale-yellow-fg);
    margin-top: 0.7rem;
  }
  .entry__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
  }
  .reslink {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: color 160ms var(--ease-out), border-color 160ms var(--ease-out),
      background-color 160ms var(--ease-out);
  }
  .reslink:hover {
    color: var(--text-strong);
    border-color: #cfcfcf;
    background: var(--surface-alt);
  }

  @media (max-width: 620px) {
    .year-block {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .year {
      position: static;
    }
  }
</style>
