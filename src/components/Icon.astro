  cap: '<path d="M3 9l9-4 9 4-9 4-9-4z"/><path d="M7 11v4.2c0 1.1 2.4 2.3 5 2.3s5-1.2 5-2.3V11"/><line x1="21" y1="9" x2="21" y2="14"/>',
