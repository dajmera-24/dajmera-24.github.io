  product: '<line x1="5" y1="6" x2="19" y2="6"/><line x1="9" y1="6" x2="9" y2="19"/><line x1="15" y1="6" x2="15" y2="19"/>',
  sqrt: '<polyline points="3 13 6 13 9 19 13 5 21 5"/>',
  partial: '<circle cx="11.5" cy="14" r="4"/><path d="M15.5 12C16 8 14 5 10.5 5.6"/>',
