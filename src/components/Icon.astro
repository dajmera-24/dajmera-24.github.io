---
interface Props {
  name: string;
  size?: number | string;
  class?: string;
  label?: string;
}
const { name, size = 20, class: className, label } = Astro.props;

// Brand glyphs render filled; everything else is stroked at a uniform width.
const filled = new Set(['github', 'linkedin', 'qed']);
const isFilled = filled.has(name);

const paths: Record<string, string> = {
