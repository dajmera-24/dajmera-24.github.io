  perpendicular: '<line x1="12" y1="5" x2="12" y2="17"/><line x1="5" y1="17" x2="19" y2="17"/>',
  parallel: '<line x1="9.5" y1="5" x2="9.5" y2="19"/><line x1="14.5" y1="5" x2="14.5" y2="19"/>',
  triangle: '<polygon points="12 4 20 19 4 19"/>',
  cube: '<path d="M12 3l8 4.5v9L12 21 4 16.5v-9z"/><polyline points="4 7.5 12 12 20 7.5"/><line x1="12" y1="12" x2="12" y2="21"/>',
