---
interface Props {
  label: string;
  variant?: 'red' | 'blue' | 'green' | 'yellow' | 'violet' | 'neutral';
}
const { label, variant } = Astro.props;

const palette = ['red', 'blue', 'green', 'yellow', 'violet'] as const;
// Deterministic pastel so the same label always gets the same accent.
function pick(s: string) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
  return palette[h % palette.length];
}
const v = variant ?? pick(label);
const cls = v === 'neutral' ? 'tag' : `tag tag--${v}`;
---

<span class={cls}>{label}</span>
